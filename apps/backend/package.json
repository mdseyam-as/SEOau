{
  "name": "@seoau/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API for SEOau Telegram WebApp",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "npm run db:generate -w @seoau/db",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "npm run db:generate -w @seoau/db",
    "db:push": "npm run db:push -w @seoau/db",
    "db:seed": "npm run db:seed -w @seoau/db"
  },
  "dependencies": {
    "@seoau/db": "0.0.0",
    "bullmq": "^5.66.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-parse": "^1.1.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
