{
  "name": "@seoau/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "db:generate": "cd ../.. && prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:push": "cd ../.. && prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "cd ../.. && prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:deploy": "cd ../.. && prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "db:studio": "cd ../.. && prisma studio --schema=packages/db/prisma/schema.prisma",
    "db:seed": "cd ../.. && node packages/db/prisma/seed.js"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "node ./prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
