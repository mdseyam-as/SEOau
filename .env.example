# Frontend
VITE_API_URL=http://localhost:3000/api

# Backend
PORT=3000
NODE_ENV=development

# WebApp URL (for Telegram webhook in production)
WEBAPP_URL=https://your-app.twc1.net

# Database (PostgreSQL - Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Telegram
BOT_TOKEN=your_telegram_bot_token
ADMIN_TELEGRAM_IDS=987654321
TELEGRAM_AUTH_MAX_AGE=10800

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key
COMPETITOR_WATCHER_LLM_MODELS=nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-next-80b-a3b-instruct:free,google/gemma-4-31b-it:free,openrouter/free

# Knowledge Base RAG embeddings (OpenAI)
OPENAI_API_KEY=your_openai_api_key
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=180
RAG_MAX_CHUNKS_PER_FILE=120
RAG_SIMILARITY_THRESHOLD=0.35

# YooKassa (Payments)
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key
YUKASSA_WEBHOOK_SECRET=your_webhook_secret

# Security
FRONTEND_URL=https://your-app.com
DEV_BYPASS_TELEGRAM=false
