# Database (PostgreSQL with Prisma)
DATABASE_URL=postgresql://username:password@localhost:5432/seo_generator?schema=public

# Server
PORT=3000
NODE_ENV=development

# Telegram Bot
# Get your token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_IDS=your_admin_telegram_id
TELEGRAM_AUTH_MAX_AGE=10800

# YuKassa Payment
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key
YUKASSA_WEBHOOK_SECRET=your_webhook_secret

# Security
# Generate with: openssl rand -base64 32
JWT_SECRET=generate_a_secure_random_string_here
# Required for encrypting API keys in database
ENCRYPTION_KEY=generate_another_secure_random_string_32_chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redis Cache (optional - uses in-memory fallback if not set)
# REDIS_URL=redis://localhost:6379
# or for Redis Cloud/Upstash:
# REDIS_URL=redis://default:password@hostname:port

# Development only (NEVER set to true in production!)
# DEV_BYPASS_TELEGRAM=false
