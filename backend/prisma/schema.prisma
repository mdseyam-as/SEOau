generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ ====================

model User {
  id                   String    @id @default(uuid())
  telegramId           BigInt    @unique // Telegram ID может быть большим числом
  username             String?
  firstName            String
  lastName             String?

  // Роль и подписка
  role                 String    @default("user") // "user", "admin"
  planId               String    @default("free")
  subscriptionExpiry   DateTime?

  // Лимиты использования
  generationsUsed      Int       @default(0)
  lastGenerationMonth  String?   // Format: "YYYY-MM"
  generationsUsedToday Int       @default(0)
  lastGenerationDate   String?   // Format: "YYYY-MM-DD"

  // Настройки уведомлений
  notificationsEnabled Boolean   @default(true)

  // Timestamps
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  projects             Project[]
  knowledgeBaseFiles   KnowledgeBase[]
  internalLinks        InternalLinks[]
  backgroundTasks      BackgroundTask[]

  @@index([telegramId])
  @@index([planId])
}

// ==================== ТАРИФНЫЕ ПЛАНЫ ====================

model Plan {
  id                     String   @id @default(uuid())
  slug                   String   @unique // "free", "pro", "unlimited"
  name                   String
  
  // Лимиты
  maxChars               Int      @default(5000)
  maxGenerationsPerMonth Int      @default(0) // 0 = unlimited
  maxGenerationsPerDay   Int      @default(0) // 0 = unlimited
  maxKeywords            Int      @default(0) // 0 = unlimited
  
  // Разрешённые модели (JSON массив строк)
  allowedModels          String[] @default([])
  
  // Функции
  canCheckSpam           Boolean  @default(false)
  canOptimizeRelevance   Boolean  @default(false)
  canUseGeoMode          Boolean  @default(false)
  canGenerateFaq         Boolean  @default(false)
  canUseSocialPack       Boolean  @default(false)
  canAudit               Boolean  @default(false)
  canRewrite             Boolean  @default(false)
  canHumanize            Boolean  @default(false)
  
  // Ценообразование
  priceRub               Int      @default(0)
  priceStars             Int      @default(0)
  durationDays           Int      @default(30)
  
  // Флаги
  isDefault              Boolean  @default(false)
  isActive               Boolean  @default(true)
  
  // Timestamps
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ==================== ПРОЕКТЫ ====================

model Project {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  history     History[]
  monitoredPages MonitoredPage[]
  competitors Competitor[]
  projectSite ProjectSite?
  
  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

// ==================== SEO MONITORING ====================

model MonitoredPage {
  id               String              @id @default(uuid())
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url              String
  normalizedUrl    String
  label            String?
  frequency        String              @default("1h") // "15m" | "1h" | "1d"
  frequencyMinutes Int                 @default(60)
  isActive         Boolean             @default(true)

  lastCheckedAt    DateTime?
  nextCheckAt      DateTime            @default(now())
  lastStatusCode   Int?
  lastFinalUrl     String?
  lastTitle        String?
  lastSeverity     String?
  lastEventAt      DateTime?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  snapshots        MonitoringSnapshot[]
  events           MonitoringEvent[]

  @@unique([projectId, normalizedUrl])
  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([isActive, nextCheckAt])
}

model MonitoringSnapshot {
  id               String            @id @default(uuid())
  monitoredPageId  String
  monitoredPage    MonitoredPage     @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)

  url              String
  finalUrl         String?
  statusCode       Int
  title            String?
  h1               String?
  metaDescription  String?
  canonical        String?
  robotsMeta       String?
  wordCount        Int               @default(0)
  contentText      String?           @db.Text
  contentHash      String?
  hasFaq           Boolean           @default(false)
  hasSchema        Boolean           @default(false)
  fetchError       String?

  createdAt        DateTime          @default(now())

  events           MonitoringEvent[] @relation("MonitoringSnapshotCurrent")
  previousFor      MonitoringEvent[] @relation("MonitoringSnapshotPrevious")

  @@index([monitoredPageId])
  @@index([monitoredPageId, createdAt(sort: Desc)])
}

model MonitoringEvent {
  id                 String             @id @default(uuid())
  monitoredPageId    String
  monitoredPage      MonitoredPage      @relation(fields: [monitoredPageId], references: [id], onDelete: Cascade)

  snapshotId         String?
  snapshot           MonitoringSnapshot? @relation("MonitoringSnapshotCurrent", fields: [snapshotId], references: [id], onDelete: SetNull)
  previousSnapshotId String?
  previousSnapshot   MonitoringSnapshot? @relation("MonitoringSnapshotPrevious", fields: [previousSnapshotId], references: [id], onDelete: SetNull)

  severity           String
  changeTypes        String[]           @default([])
  title              String
  summary            String             @db.Text
  diff               Json
  notifiedAt         DateTime?

  createdAt          DateTime           @default(now())

  @@index([monitoredPageId])
  @@index([monitoredPageId, createdAt(sort: Desc)])
  @@index([severity])
}

// ==================== COMPETITOR WATCHER ====================

model Competitor {
  id                    String                 @id @default(uuid())
  projectId             String
  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name                  String
  domain                String
  normalizedDomain      String
  homepageUrl           String
  priority              String                 @default("medium")
  scanFrequency         String                 @default("1d")
  frequencyMinutes      Int                    @default(1440)
  notes                 String?                @db.Text
  isActive              Boolean                @default(true)

  lastScannedAt         DateTime?
  nextScanAt            DateTime               @default(now())
  lastStatus            String?
  lastPageCount         Int                    @default(0)
  lastChangeCount       Int                    @default(0)
  lastClusterCount      Int                    @default(0)
  lastSummary           String?                @db.Text
  lastSeverity          String?
  lastImportantChangeAt DateTime?

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  pageSnapshots         CompetitorPageSnapshot[]
  pageChanges           CompetitorPageChange[]
  topicClusters         TopicCluster[]
  comparisons           CompetitorComparison[]

  @@unique([projectId, normalizedDomain])
  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([isActive, nextScanAt])
}

model CompetitorPageSnapshot {
  id                 String                  @id @default(uuid())
  competitorId       String
  competitor         Competitor              @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  url                String
  normalizedUrl      String
  finalUrl           String?
  statusCode         Int
  title              String?
  h1                 String?
  h2List             String[]                @default([])
  h3List             String[]                @default([])
  metaDescription    String?
  canonical          String?
  faqQuestions       String[]                @default([])
  contentText        String?                 @db.Text
  wordCount          Int                     @default(0)
  contentHash        String?
  structureHash      String?
  ctaText            String?
  internalLinks      String[]                @default([])
  pageType           String?
  topicKey           String?
  semanticSummary    String?                 @db.Text
  fetchError         String?
  isDeletedPage      Boolean                 @default(false)

  scannedAt          DateTime                @default(now())

  changesCurrent     CompetitorPageChange[]  @relation("CompetitorSnapshotCurrent")
  changesPrevious    CompetitorPageChange[]  @relation("CompetitorSnapshotPrevious")

  @@index([competitorId])
  @@index([competitorId, scannedAt(sort: Desc)])
  @@index([competitorId, normalizedUrl])
  @@index([competitorId, normalizedUrl, scannedAt(sort: Desc)])
}

model CompetitorPageChange {
  id                 String                   @id @default(uuid())
  competitorId       String
  competitor         Competitor               @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  snapshotId         String?
  snapshot           CompetitorPageSnapshot?  @relation("CompetitorSnapshotCurrent", fields: [snapshotId], references: [id], onDelete: SetNull)
  previousSnapshotId String?
  previousSnapshot   CompetitorPageSnapshot?  @relation("CompetitorSnapshotPrevious", fields: [previousSnapshotId], references: [id], onDelete: SetNull)

  url                String
  normalizedUrl      String
  severity           String
  changeType         String
  changeTypes        String[]                 @default([])
  pageType           String?
  topicKey           String?
  significanceScore  Int                      @default(0)
  impactScore        Int                      @default(0)
  isImportant        Boolean                  @default(false)
  title              String
  summary            String                   @db.Text
  diff               Json
  notifiedAt         DateTime?
  detectedAt         DateTime                 @default(now())

  @@index([competitorId])
  @@index([competitorId, detectedAt(sort: Desc)])
  @@index([competitorId, isImportant, detectedAt(sort: Desc)])
  @@index([severity])
}

model TopicCluster {
  id          String      @id @default(uuid())
  competitorId String
  competitor  Competitor  @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  key         String
  name        String
  keywords    String[]    @default([])
  pageCount   Int         @default(0)
  trendScore  Int         @default(0)
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([competitorId, key])
  @@index([competitorId])
}

model CompetitorComparison {
  id             String      @id @default(uuid())
  competitorId   String
  competitor     Competitor  @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  topicKey       String
  ourTopic       String
  theirTopic     String
  ourCoverage    Int         @default(0)
  theirCoverage  Int         @default(0)
  gapSummary     String      @db.Text
  recommendation String      @db.Text

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([competitorId, topicKey])
  @@index([competitorId])
}

// ==================== OUR SITE ====================

model ProjectSite {
  id               String                  @id @default(uuid())
  projectId        String                  @unique
  project          Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name             String?
  domain           String
  normalizedDomain String
  homepageUrl      String
  scanFrequency    String                  @default("1d")
  frequencyMinutes Int                     @default(1440)
  isActive         Boolean                 @default(true)

  lastScannedAt    DateTime?
  nextScanAt       DateTime                @default(now())
  lastStatus       String?
  lastPageCount    Int                     @default(0)
  lastSummary      String?                 @db.Text
  lastImportedAt   DateTime?

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  pageSnapshots    ProjectSitePageSnapshot[]

  @@index([projectId])
  @@index([isActive, nextScanAt])
}

model ProjectSitePageSnapshot {
  id              String      @id @default(uuid())
  projectSiteId   String
  projectSite     ProjectSite @relation(fields: [projectSiteId], references: [id], onDelete: Cascade)

  url             String
  normalizedUrl   String
  finalUrl        String?
  statusCode      Int
  title           String?
  h1              String?
  h2List          String[]    @default([])
  h3List          String[]    @default([])
  metaDescription String?
  canonical       String?
  faqQuestions    String[]    @default([])
  contentText     String?     @db.Text
  wordCount       Int         @default(0)
  contentHash     String?
  structureHash   String?
  ctaText         String?
  internalLinks   String[]    @default([])
  pageType        String?
  topicKey        String?
  fetchError      String?
  isDeletedPage   Boolean     @default(false)

  scannedAt       DateTime    @default(now())

  @@index([projectSiteId])
  @@index([projectSiteId, scannedAt(sort: Desc)])
  @@index([projectSiteId, normalizedUrl])
  @@index([projectSiteId, normalizedUrl, scannedAt(sort: Desc)])
}

// ==================== ИСТОРИЯ ГЕНЕРАЦИЙ ====================

model History {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Основные поля
  topic       String
  targetUrl   String?
  mode        String   @default("geo") // "seo" | "geo"
  
  // JSON поля для хранения сложных структур
  config      Json     // GenerationConfig
  result      Json     // SeoResult (включает article, visuals, faq, seo)

  // AIO/GEO structured output for AI Search Optimization
  knowledgeGraph  Json?
  ragChunks       Json?
  jsonLd          Json?
  markdownContent String? @db.Text
  
  // Timestamps
  createdAt   DateTime @default(now())
  
  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
}

// ==================== СИСТЕМНЫЕ НАСТРОЙКИ ====================

model SystemSetting {
  id        String   @id @default("global")
  
  // API ключи
  openRouterApiKey String?
  
  // Промпты
  seoPrompt        String?  @db.Text
  geoPrompt        String?  @db.Text
  
  // Настройки
  telegramLink     String   @default("https://t.me/bankkz_admin")
  spamCheckModel   String   @default("x-ai/grok-4.1-fast")
  
  // Timestamps
  updatedAt        DateTime @updatedAt
}

// ==================== ПЛАТЕЖИ (для ЮKassa) ====================

model Payment {
  id              String   @id @default(uuid())

  // Связь с пользователем (по telegramId для простоты)
  telegramId      BigInt

  // Данные платежа
  yookassaId      String?  @unique // ID платежа в ЮKassa
  planSlug        String   // Какой план покупается
  amount          Int      // Сумма в копейках
  currency        String   @default("RUB")

  // Статус
  status          String   @default("pending") // "pending", "succeeded", "canceled"

  // Timestamps
  createdAt       DateTime @default(now())
  paidAt          DateTime?

  @@index([telegramId])
  @@index([yookassaId])
  @@index([status])
}

// ==================== БАЗА ЗНАНИЙ (RAG) ====================

model KnowledgeBase {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName    String
  fileType    String   // "pdf" | "docx" | "txt"
  fileSize    Int      // в байтах

  content     String   @db.Text   // извлечённый текст
  embeddings  Json?    // векторные представления

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

// ==================== ВНУТРЕННИЕ ССЫЛКИ ====================

model InternalLinks {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  url         String
  anchorText  String?
  keywords    String[] // ключевые слова для контекстной вставки
  priority    Int      @default(0) // приоритет ссылки

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, priority(sort: Desc)])
}

// ==================== ФОНОВЫЕ ЗАДАЧИ ====================

model BackgroundTask {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String    // "generate" | "rewrite" | "humanize"
  status      String    @default("pending") // "pending" | "processing" | "completed" | "failed"
  config      Json      // конфигурация задачи
  result      Json?     // результат выполнения
  error       String?   // текст ошибки

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([userId, createdAt(sort: Desc)])
}

// ==================== БЛОКИРОВКИ ПРОЦЕССОВ ====================
// Для предотвращения дублирования фоновых процессов при горизонтальном масштабировании

model ProcessLock {
  name        String   @id // "task-queue", "telegram-bot", "history-cleanup"
  instanceId  String   // UUID инстанса который держит блокировку
  acquiredAt  DateTime @default(now())
  expiresAt   DateTime // Блокировка истекает если не обновляется

  @@index([expiresAt])
}
