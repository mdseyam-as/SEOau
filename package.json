{
  "name": "seoau",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @seoau/frontend",
    "dev:backend": "npm run dev -w @seoau/backend",
    "build": "npm run build -w @seoau/frontend",
    "build:platform": "node scripts/build-platform.mjs",
    "start:platform": "npm run start -w @seoau/backend",
    "preview": "npm run preview -w @seoau/frontend",
    "test": "npm run test -w @seoau/frontend",
    "test:backend": "npm run test -w @seoau/backend",
    "test:coverage": "npm run test:coverage -w @seoau/frontend",
    "db:generate": "npm run db:generate -w @seoau/db",
    "db:push": "npm run db:push -w @seoau/db",
    "db:migrate": "npm run db:migrate -w @seoau/db",
    "db:deploy": "npm run db:deploy -w @seoau/db",
    "db:seed": "npm run db:seed -w @seoau/db",
    "db:studio": "npm run db:studio -w @seoau/db"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prisma": "^5.22.0",
    "typescript": "~5.8.2"
  }
}
